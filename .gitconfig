# This is Git's per-user configuration file.
[user]
	email = helagro@outlook.com
	signingkey = ssh-rsa 
	name = Henrik Lagrosen
# Please adapt and uncomment the following lines:
#	name = Henrik L
#	email = h@Henriks-MacBook-Air.local
[core]
	editor = code --wait
	commentChar = ";"
	excludesFile = /Users/h/.gitignore
[push]
	autoSetupRemote = true
[init]
	defaultBranch = main
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = false
